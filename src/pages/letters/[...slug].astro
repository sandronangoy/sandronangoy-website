---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Cover from '../../components/Cover.astro';
import { fmtDate } from '../../utils';
export async function getStaticPaths() {
  const letters = await getCollection('letters', (e) => !e.data.draft);
  return letters.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={entry.data.title} description={entry.data.dek}>
  <article class="wrap article">
    <div class="article-cover">
      <Cover title={entry.data.title} tag={entry.data.coverLabel} image={entry.data.coverImage} />
    </div>
    <div class="kicker">{fmtDate(entry.data.date)} · letter</div>
    <h1>{entry.data.title}</h1>
    {entry.data.dek && <p class="dek">{entry.data.dek}</p>}
    <div class="prose"><Content /></div>
    <a class="backlink" href="/letters/">← all letters</a>
  </article>
</Base>
