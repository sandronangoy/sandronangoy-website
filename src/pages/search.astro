---
import Base from '../layouts/Base.astro';
---
<Base title="Search" description="Search the letters, thread, and models.">
  <section class="wrap" style="padding-top: 52px;">
    <p class="eyebrow">search</p>
    <h1 style="font-weight:300;font-size:34px;margin:0 0 18px;">find anything I've written.</h1>
    <input id="q" type="search" placeholder="search letters, thread, models…" autocomplete="off"
      style="width:100%;padding:14px 16px;font-family:'Spectral',serif;font-size:17px;color:var(--ink);background:#F7F3EA;border:0.5px solid var(--line);border-radius:12px;outline:none;" />
    <div id="count" style="font-size:13px;color:var(--faint);margin:14px 0 0;"></div>
    <div id="results" style="margin-top:6px;"></div>
  </section>

  <script is:inline>
    (async function () {
      const q = document.getElementById('q');
      const results = document.getElementById('results');
      const count = document.getElementById('count');
      let data = [];
      try {
        data = await (await fetch('/search-index.json')).json();
      } catch (e) {}

      const esc = (s) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const fmt = (d) => {
        const p = d.split('-');
        const mon = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'][parseInt(p[1],10)-1];
        return p[2] + ' ' + mon + ' ' + p[0];
      };

      function render(list, query) {
        if (!query) { results.innerHTML = ''; count.textContent = ''; return; }
        if (!list.length) { results.innerHTML = '<p style="color:var(--muted);padding:20px 0;">nothing yet for “' + esc(query) + '”.</p>'; count.textContent = ''; return; }
        count.textContent = list.length + (list.length === 1 ? ' result' : ' results');
        results.innerHTML = list.map(function (it) {
          const head = it.title ? esc(it.title) : esc(it.text.slice(0, 80)) + (it.text.length > 80 ? '…' : '');
          const sub = it.title ? esc(it.dek || it.text.slice(0, 130) + '…') : '';
          return '<a class="entry" href="' + it.url + '">' +
            '<div class="date">' + fmt(it.date) + ' · ' + it.type + '</div>' +
            '<h3>' + head + '</h3>' +
            (sub ? '<p>' + sub + '</p>' : '') +
            '</a>';
        }).join('');
      }

      function search(query) {
        const t = query.trim().toLowerCase();
        if (!t) return [];
        return data.filter(function (it) {
          return (it.title + ' ' + it.dek + ' ' + it.text + ' ' + it.type).toLowerCase().includes(t);
        });
      }

      let timer;
      q.addEventListener('input', function () {
        clearTimeout(timer);
        timer = setTimeout(function () { render(search(q.value), q.value.trim()); }, 120);
      });

      const params = new URLSearchParams(location.search);
      if (params.get('q')) { q.value = params.get('q'); render(search(q.value), q.value.trim()); }
      q.focus();
    })();
  </script>
</Base>
